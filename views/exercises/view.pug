extends layout

block firstTab
  if exercise.flags && exercise.flags.indexOf("unapproved") != -1
    .alert.alert-warning
      strong Unapproved <!--space-->
      | This exercise was not yet verified to be correct
  if exercise.flags && exercise.flags.indexOf("incorrect") != -1
    .alert.alert-danger
      strong Attention! <!--space-->
      | There are mistakes in this exercise! Please help to correct them!

  #task!= exercise.task

  if exercise.hints
    #hints
      each hint, index in exercise.hints
        .card.mb-2
          .card-header(role='button',
            data-bs-toggle='collapse',
            data-bs-target='#hint-' + (index+1))
            span Hint #{index+1}
          .collapse(id='hint-' + (index+1))
            .card-body!= hint

    br

  if exercise.approach
    #approach
      .card.mb-2
        .card-header(role='button',
          data-bs-toggle='collapse', data-bs-target='#approachBody')
          span.card-title Approach
        #approachBody.collapse
          .card-body
            != exercise.approach

    br

  if exercise.solutions && exercise.solutions.length > 0
    #solution
      .card.border-primary
        .card-header.bg-primary.text-white(role='button',
          data-bs-toggle='collapse',
          data-bs-target='#solution .list-group')
          span.card-title Solution
            = (exercise.solutions.length === 1) ? '' : 's'

        if exercise.solutions && exercise.solutions.length > 0
          ul.list-group.list-group-flush.collapse
            each solution in exercise.solutions
              li.list-group-item!= solution

        else if exercise.solution
          .alert.alert-success
            != exercise.solution
        // TODO: remove because deprecated

  if !exercise.solutions && !exercise.approach
    a(href='/exercises/' + exercise.slug + '/edit', class='btn btn-secondary btn-lg', role='button')
      | Add a Solution


block sidebar
  #exerciseSidebar.col-sm-3
    ul.list-group
      li.list-group-item URL:
        input.form-control.form-control-sm(
        type='url',
        readonly=true,
        value= settings.hostname + '/e/' + exercise.slug
        )

      li.list-group-item Language: <!--space-->
        span.float-end= exercise.language

      li.list-group-item Subjects: <!--space-->
        if exercise.subjects
          each subject in exercise.subjects
            a.badge.text-bg-secondary.text-decoration-none(
              href='/exercises?subject=' + encodeURIComponent(subject)
            )= subject
            = ' '

      li.list-group-item Type: <!--space-->
        span.float-end= exercise.type

      li.list-group-item Duration: <!--space-->
        if exercise.duration
          span.float-end= exercise.duration
            | min

      li.list-group-item Credits: <!--space-->
        span.badge.text-bg-secondary.float-end= exercise.credits

      li.list-group-item Difficulty: <!--space-->
        if exercise.difficulty !== undefined
          span.float-end= exercise.difficulty
          .progress
            .progress-bar(style=`width: ${exercise.difficulty * 100}%`)

      li.list-group-item Tags: <!--space-->
        if exercise.tags
          each tag in exercise.tags
            a.badge.text-bg-secondary.text-decoration-none(
              href='/exercises?tag=' + encodeURIComponent(tag)
            )= tag
            = ' '

      li.list-group-item Note: <!--space-->
        br
        small.text-muted
          = exercise.note

      li.list-group-item Created By: <!--space-->
        if exercise.createdBy
          a.float-end(href='/' + exercise.createdBy)
            = exercise.createdBy

      li.list-group-item Created At: <!--space-->
        if exercise.originalCreatedAt
          - var createdAt = exercise.originalCreatedAt.toISOString().substr(0, 19).split('T').join(' ')
          br
          small.text-muted
            = createdAt + ' UTC'

      li.list-group-item Last Modified: <!--space-->
        if exercise.updatedAt
          - var updatedAt = exercise.updatedAt.toISOString().substr(0, 19).split('T').join(' ')
          br
          small.text-muted
            = updatedAt + ' UTC'

block scripts
  script.
    hljs.highlightAll()
    MathJax = {
      loader: {
        load: ['input/asciimath', 'output/chtml']
      },
      asciimath: {
        delimiters: [['´','´']],
      },
    }

    document.addEventListener('shown.bs.collapse', (event) => {
      if (window.MathJax && MathJax.typesetPromise) {
        MathJax.typesetPromise([event.target])
      }
    })

  script(async src='/modules/mathjax/tex-mml-chtml.js')
