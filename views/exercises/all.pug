extends ../layout

block content
  form.row.g-2.align-items-end.mb-3(action='/exercises', method='get')
    if filter && filter.q
      input(type='hidden', name='q', value=filter.q)
    .col-sm-4
      label.form-label.small.mb-1(for='filterSubject') Subject
      input#filterSubject.form-control.form-control-sm(
        type='text',
        name='subject',
        list='subjectOptions',
        autocomplete='off',
        value=(filter && filter.subject) ? filter.subject : '',
        placeholder='e.g. Math'
      )
      datalist#subjectOptions
        if allSubjects
          each subject in allSubjects
            option(value=subject)
    .col-sm-4
      label.form-label.small.mb-1(for='filterTag') Tag
      input#filterTag.form-control.form-control-sm(
        type='text',
        name='tag',
        list='tagOptions',
        autocomplete='off',
        value=(filter && filter.tag) ? filter.tag : '',
        placeholder='e.g. proof'
      )
      datalist#tagOptions
        if allTags
          each tag in allTags
            option(value=tag)
    .col-sm-4.d-flex.gap-2
      button.btn.btn-sm.btn-primary(type='submit') Filter
      if filter && (filter.tag || filter.subject || filter.q)
        a.btn.btn-sm.btn-outline-secondary(href='/exercises') Clear

  if filter && filter.q
    p.text-muted.small.mb-3
      | Showing results for #[strong=filter.q]

  if exercises.length === 0
    if filter && (filter.tag || filter.subject || filter.q)
      h1.pb-2.mb-4.border-bottom.
        No exercises match the selected filter.
    else
      h1.pb-2.mb-4.border-bottom.
        There are no exercises available yet.
        #[br]
        #[small Please sign up and create the first ones!]

  else
    .table-responsive
      table#exercisesTable.table.table-striped.table-bordered.table-sm
        thead
          tr
            th Nr
            th Subjects
            th Type
            th Task
            th Difficulty
            th Credits
            th Tags
            th Flags
            th Note

        tbody
          each exercise, index in exercises
            tr
              td= (pagination ? pagination.startIndex : 0) + index + 1
              td.small
                if exercise.subjects && exercise.subjects.length
                  each subject, subjectIndex in exercise.subjects
                    a.badge.text-bg-secondary.text-decoration-none.me-1(
                      href='/exercises?subject=' + encodeURIComponent(subject)
                    )= subject
              td.small= exercise.type
              td.small
                - var task = exercise.task
                a(
                href= exercise.url,
                title= task ? task : ''
                )
                  =(task) ? task.substr(0, 80) + '…' : ''
              td
                if exercise.difficulty
                  span.text-muted.small= exercise.difficulty
                  .progress
                    .progress-bar.bg-secondary(style=`width: ${exercise.difficulty * 100}%`)

              td
                if exercise.credits
                  span.badge.rounded-pill.text-bg-secondary
                    = exercise.credits

              td
                if exercise.tags && exercise.tags.length
                  each tag in exercise.tags
                    a.badge.text-bg-secondary.text-decoration-none.me-1(
                      href='/exercises?tag=' + encodeURIComponent(tag)
                    )= tag

              td.text-center
                if !exercise.solutions && !exercise.approach
                  span.text-danger ✗

              td.small.text-muted
                = (exercise.note) ? exercise.note : ''

    if pagination && pagination.totalPages > 1
      - var qs = pagination.queryString ? pagination.queryString + '&' : ''
      - var rangeStart = pagination.startIndex + 1
      - var rangeEnd = Math.min(pagination.startIndex + pagination.pageSize, pagination.totalCount)
      nav.d-flex.justify-content-between.align-items-center.mt-3(aria-label='Exercise pagination')
        .small.text-muted
          | Showing #{rangeStart}–#{rangeEnd} of #{pagination.totalCount}
        ul.pagination.pagination-sm.mb-0
          li.page-item(class=(pagination.currentPage <= 1) ? 'disabled' : '')
            a.page-link(
              href=(pagination.currentPage > 1) ? '?' + qs + 'page=' + (pagination.currentPage - 1) : '#',
              aria-label='Previous'
            ) ‹ Prev
          - var windowStart = Math.max(1, pagination.currentPage - 2)
          - var windowEnd = Math.min(pagination.totalPages, pagination.currentPage + 2)
          if windowStart > 1
            li.page-item
              a.page-link(href='?' + qs + 'page=1') 1
            if windowStart > 2
              li.page-item.disabled
                span.page-link …
          - for (var p = windowStart; p <= windowEnd; p++)
            li.page-item(class=(p === pagination.currentPage) ? 'active' : '')
              a.page-link(href='?' + qs + 'page=' + p)= p
          if windowEnd < pagination.totalPages
            if windowEnd < pagination.totalPages - 1
              li.page-item.disabled
                span.page-link …
            li.page-item
              a.page-link(href='?' + qs + 'page=' + pagination.totalPages)= pagination.totalPages
          li.page-item(class=(pagination.currentPage >= pagination.totalPages) ? 'disabled' : '')
            a.page-link(
              href=(pagination.currentPage < pagination.totalPages) ? '?' + qs + 'page=' + (pagination.currentPage + 1) : '#',
              aria-label='Next'
            ) Next ›
